MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=idx_ai_agent
MYSQL_DATABASE=idx_exchange

# Recommended on macOS: keep the real password in Keychain.
MYSQL_PASSWORD_KEYCHAIN_SERVICE=IDX_AI_MYSQL

# Optional fallback for non-macOS environments. Never commit a real value.
MYSQL_PASSWORD=

# Add these only when the corresponding weeks need them.
OPENAI_API_KEY=
EMAIL_USER=
EMAIL_PASSWORD=
